# Environment variables for Financial Forecasting MVP Backend

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=financial_forecasting
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# JWT Authentication
JWT_SECRET=your-jwt-secret-here-change-in-production

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:8501

# Forecasting Configuration
CSV_MAX_ROWS=100000

# Logging
LOG_LEVEL=INFO

